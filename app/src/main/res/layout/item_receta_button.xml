<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutReceta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/edittext_background"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:padding="12dp">

    <TextView
        android:id="@+id/txtNombreReceta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textColor="@color/colorIcono"
        android:textSize="16sp"
        tools:text="Nombre de la receta" />

    <ImageView
        android:id="@+id/imgRecent"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@string/ultima_fecha_calendario"
        android:src="@drawable/ic_calendar"
        android:tint="@color/colorIcono"
        android:visibility="gone"
        tools:ignore="UseAppTint" />

    <ImageView
        android:id="@+id/imgType"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/imgWarning"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/warning"
        android:visibility="gone"
        android:contentDescription="@string/warning" />

    <ImageView
        android:id="@+id/imgBadge"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        tools:src="@android:color/darker_gray"
        android:contentDescription="@null" />

</LinearLayout>
