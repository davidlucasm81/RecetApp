<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="30dp"
        tools:ignore="RtlSymmetry">

        <TextView
            android:id="@+id/txtNombreReceta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textStyle="bold"
            android:focusable="false"
            android:clickable="false" />

        <TextView
            android:id="@+id/txtMomento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorGrisTextoFondo"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/warning"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/warning"
            android:src="@drawable/warning"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imageViewTipoIcono"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/tipo_principal"
            android:src="@drawable/postre_icono"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnEliminar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/eliminar"
            android:src="@drawable/ic_baseline_delete_24"
            android:focusable="false"
            tools:ignore="TouchTargetSizeCheck" />

    </LinearLayout>

</LinearLayout>
