<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>

    <!-- Required for Google Play Services visibility and features on newer Android versions -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <queries>
        <!-- Google Play Services visibility -->
        <package android:name="com.google.android.gms" />
        <package android:name="com.android.vending" />
        <intent>
            <action android:name="com.google.android.gms.settings.ads.IDENTIFIER_SERVICE" />
        </intent>
        <intent>
            <action android:name="com.google.android.gms.auth.api.signin.SERVICE" />
        </intent>
    </queries>

    <application
        android:icon="@mipmap/icono_app_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecetApp">

        <!-- Explicitly define GMS version -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- FileProvider para compartir archivos de la app de manera segura -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.david.recetapp.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Actividades principales -->
        <activity
            android:name=".actividades.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity android:name=".actividades.recetas.AddRecetaActivity" />
        <activity android:name=".actividades.recetas.EditarRecetaActivity" />
        <activity android:name=".actividades.ImportExportActivity" />
        <activity android:name=".actividades.DetalleDiaActivity" />
        <activity android:name=".actividades.AddRecetaDiaActivity" />

    </application>

</manifest>